{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/idle",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/cron/workload",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/v1/cron/daily",
      "schedule": "59 23 * * *"
    }
  ]
}
