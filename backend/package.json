    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "install": "^0.13.0",
    "jest": "^30.3.0",
    "n": "^10.2.0",
    "node-cron": "^4.2.1",
    "npm": "^11.11.1",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
