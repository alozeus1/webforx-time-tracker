# Core runtime
DATABASE_URL="postgresql://postgres:password@localhost:5432/webforx_tracker"
JWT_SECRET="replace-with-a-long-random-local-secret"
INTEGRATION_SECRET="replace-with-a-second-long-random-local-secret"
CRON_SECRET="replace-with-a-local-cron-secret"
PORT=5005
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
FRONTEND_URL="http://localhost:5173,http://127.0.0.1:5173"
ENABLE_BACKGROUND_WORKERS=true

# Timer/idle guardrails
IDLE_WARNING_MINUTES=5
HEARTBEAT_INTERVAL_MINUTES=3
HEARTBEAT_STALE_MINUTES=8
AUTO_STOP_GRACE_MINUTES=2
MAX_PAUSE_HOURS=4
MAX_ACTIVE_TIMER_HOURS=8

# Optional deterministic local seed passwords
SEED_ADMIN_PASSWORD="ChangeMe-Admin-Local"
SEED_MANAGER_PASSWORD="ChangeMe-Manager-Local"
SEED_EMPLOYEE_PASSWORD="ChangeMe-Employee-Local"
ALLOW_DEFAULT_SEED_CREDENTIALS=false

# Optional public demo seed support
SEED_DEMO_USER=false
SEED_DEMO_PASSWORD="ChangeMe-Demo-Local"

# Optional outbound email (safe to leave blank locally)
RESEND_API_KEY=""
EMAIL_FROM="Web Forx Time Tracker <noreply@example.com>"

# Optional Google Calendar integration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:5005/api/v1/calendar/callback"

# Optional Authentik/OIDC integration
AUTHENTIK_ENABLED=false
AUTHENTIK_ISSUER_URL="https://auth.example.com/application/o/time-tracker"
AUTHENTIK_CLIENT_ID=""
AUTHENTIK_CLIENT_SECRET=""
AUTHENTIK_REDIRECT_URI="http://localhost:5005/api/v1/auth/authentik/callback"
AUTHENTIK_POST_LOGOUT_REDIRECT_URI="http://localhost:5173/login"
AUTHENTIK_SCOPES="openid profile email"
